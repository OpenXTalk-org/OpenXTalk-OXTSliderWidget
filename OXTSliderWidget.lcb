private variable mThumbVector as optional Path
private variable mThumbSVGPath as optional String
property thumbSVGPath         get mThumbSVGPath           set setThumbSVGPath
metadata thumbSVGPath.editor is "com.livecode.pi.string"
metadata thumbSVGPath.label   is "Custom Thumb SVGPath"
metadata thumbSVGPath.default is "M 16 0 A 16 16 0 1 0 16 32 A 16 16 0 1 0 16 0"

private handler setThumbSVGPath(in pSVGPath as String)
    if char 1 of pSVGPath is "M" or char 1 of pSVGPath is "m" then
		 if char -1 of pSVGPath is "Z" or char -1 of pSVGPath is "z" then
			 variable tThumbBounds as optional Rectangle
			 -- put "custom" into mThumbShape
			 setThumbShape("custom")
			 put pSVGPath into mThumbSVGPath
			 put path pSVGPath into mThumbVector

          constrainPathToRect( rectangle [0,0,40,40], mThumbVector ) --- constrainPathToRect is in  com.livecode.library.widgetutils

			 put the bounding box of mThumbVector into tThumbBounds
			 put the height of tThumbBounds into mThumbHeight
			 put the width of tThumbBounds into mThumbWidth
		 else
			 throw "Thumb SVG path strings should be closed paths ending with char 'Z' or 'z'"
       end if
	 else
		 throw "Thumb SVG path strings must begin a move instruction beginning with char 'M' or 'm'"
	 end if

	 OnGeometryChanged()
	 redraw all
end handler

private variable mThumbShape          as optional String
property thumbShape          get mThumbShape           set setThumbShape
metadata thumbShape.editor is "com.livecode.pi.enum"
metadata thumbShape.label   is "Thumb Style"
metadata thumbShape.default is "thumb"
metadata thumbShape.options is "none,pin,thumb,rectangular,notch,rectangle,circle,custom"

private handler setThumbShape(in pStyle as String)
	variable tThumbBounds as optional Rectangle

    if pStyle is "none" then
    	put path "" into mThumbVector
		put "" into mThumbSVGPath
    else if pStyle is "thumb" then
        put path "M19.957,39.487c7.348,0,13.839-10.771,15.539-14.278s2.589-11.26,2.589-13.175v-3.241c0-.025,0-3.392,0-3.392,0-1.915-1.159-3.467-2.589-3.467,0,0-8.308-.711-15.539-.687-7.231.024-15.453.687-15.453.687-1.43,0-2.589,1.552-2.589,3.467v6.633c0,1.915.648,9.725,2.589,13.175s6.865,14.278,15.453,14.278Z" into mThumbVector
		  put "M19.957,39.487c7.348,0,13.839-10.771,15.539-14.278s2.589-11.26,2.589-13.175v-3.241c0-.025,0-3.392,0-3.392,0-1.915-1.159-3.467-2.589-3.467,0,0-8.308-.711-15.539-.687-7.231.024-15.453.687-15.453.687-1.43,0-2.589,1.552-2.589,3.467v6.633c0,1.915.648,9.725,2.589,13.175s6.865,14.278,15.453,14.278Z" into mThumbSVGPath
    else if pStyle is "rectangular" then
		put path "M12.37,17.51c.17-7.09-1.3-15.01-1.3-15.01C11.08,1.12,9.96,0,8.58,0h-2.34S3.8,0,3.8,0C2.41,0,1.3,1.12,1.3,2.5,1.3,2.5-.02,10.52,0,17.51s1.3,14.92,1.3,14.92c0,1.38,1.12,2.5,2.5,2.5h4.78c1.38,0,2.5-1.12,2.5-2.5,0,0,1.13-7.83,1.3-14.92Z" into mThumbVector
		put "M12.37,17.51c.17-7.09-1.3-15.01-1.3-15.01C11.08,1.12,9.96,0,8.58,0h-2.34S3.8,0,3.8,0C2.41,0,1.3,1.12,1.3,2.5,1.3,2.5-.02,10.52,0,17.51s1.3,14.92,1.3,14.92c0,1.38,1.12,2.5,2.5,2.5h4.78c1.38,0,2.5-1.12,2.5-2.5,0,0,1.13-7.83,1.3-14.92Z" into mThumbSVGPath
	else if pStyle is "rectangle" then
		put path "M19.5,35.94H0V0h19.49v35.93h0Z" into mThumbVector
		put "M19.5,35.94H0V0h19.49v35.93h0Z" into mThumbSVGPath
	 else if pStyle is "pin" then
      	put path "M6.936,39.115c2.082,0,3.921-10.771,4.403-14.278s.734-11.26.734-13.175v-3.241c0-.025,0-3.392,0-3.392,0-1.915-.328-3.467-.734-3.467,0,0-2.354-.711-4.403-.687s-4.379.687-4.379.687c-.405,0-.734,1.552-.734,3.467v6.633c0,1.915.184,9.725.734,13.175s1.945,14.278,4.379,14.278Z" into mThumbVector
			put "M6.936,39.115c2.082,0,3.921-10.771,4.403-14.278s.734-11.26.734-13.175v-3.241c0-.025,0-3.392,0-3.392,0-1.915-.328-3.467-.734-3.467,0,0-2.354-.711-4.403-.687s-4.379.687-4.379.687c-.405,0-.734,1.552-.734,3.467v6.633c0,1.915.184,9.725.734,13.175s1.945,14.278,4.379,14.278Z" into mThumbSVGPath
	 else if pStyle is "circle" then
		 -- put circle path centered at point [16,16] with radius 16 into mThumbVector
		put path "M 16 0 A 16 16 0 1 0 16 32 A 16 16 0 1 0 16 0" into mThumbVector
		put "M 16 0 A 16 16 0 1 0 16 32 A 16 16 0 1 0 16 0" into mThumbSVGPath
	else if pStyle is "notch" then
		 -- put circle path centered at point [16,16] with radius 16 into mThumbVector
		put path "M19.11,32.43c0,1.38-1.93,2.5-4.31,2.5H6.55c-2.38,0-4.31-1.12-4.31-2.5C2.24,32.43.03,24.49,0,17.51S2.24,2.5,2.24,2.5C2.24,1.12,4.17,0,6.55,0,6.55,0,10.74,0,10.77,0h4.03C17.18,0,19.11,1.12,19.11,2.5c0,0,2.53,7.91,2.23,15.01s-2.23,14.92-2.23,14.92ZM14.51,17.49c.1-4.91-.8-10.38-.8-10.38,0-.96-.69-1.73-1.55-1.73h-1.45s-1.51,0-1.51,0c-.85,0-1.55.77-1.55,1.73,0,0-.81,5.55-.8,10.38s.8,10.32.8,10.32c0,.96.69,1.73,1.55,1.73h2.96c.85,0,1.55-.77,1.55-1.73,0,0,.7-5.42.8-10.32Z" into mThumbVector
		put "M19.11,32.43c0,1.38-1.93,2.5-4.31,2.5H6.55c-2.38,0-4.31-1.12-4.31-2.5C2.24,32.43.03,24.49,0,17.51S2.24,2.5,2.24,2.5C2.24,1.12,4.17,0,6.55,0,6.55,0,10.74,0,10.77,0h4.03C17.18,0,19.11,1.12,19.11,2.5c0,0,2.53,7.91,2.23,15.01s-2.23,14.92-2.23,14.92ZM14.51,17.49c.1-4.91-.8-10.38-.8-10.38,0-.96-.69-1.73-1.55-1.73h-1.45s-1.51,0-1.51,0c-.85,0-1.55.77-1.55,1.73,0,0-.81,5.55-.8,10.38s.8,10.32.8,10.32c0,.96.69,1.73,1.55,1.73h2.96c.85,0,1.55-.77,1.55-1.73,0,0,.7-5.42.8-10.32Z" into mThumbSVGPath
	else if pStyle is "custom" then
		-- Do nothing
	end if
	put pStyle into mThumbShape

	put the bounding box of mThumbVector into tThumbBounds
	put the height of tThumbBounds into mThumbHeight
	put the width of tThumbBounds into mThumbWidth

	OnMouseMove()
	OnGeometryChanged()
	redraw all
end handler

--------------------------------------------------------------------------  Save & Load --------------------------------------------------------------------------------------

public handler OnSave(out rProp as Array)
	put mCornerRadius into rProp["cornerRadius"]
	put mHoriz into rProp["horizontalOrentation"]
	put mBorderWidth into rProp["borderWidth"]
	put mThumbSVGPath into rProp["thumbSVGPath"]
	put mThumbShape into rProp["thumbShape"]
	put mMargin into rProp["margin"]
	if mHiliteColor is not nothing then
		put colorToString( mHiliteColor, true ) into rProp["hiliteColor"]
	end if
	if mThumbFillColor is not nothing then
		put colorToString( mThumbFillColor, true ) into rProp["thumbFillColor"]
	end if
	if mLabel is not nothing and mLabel is not the empty string then
		put mLabel into rProp["label"]
	end if
	if mLabelTextColor is not nothing then
		put colorToString( mLabelTextColor, true ) into rProp["labelTextColor"]
	end if
	if mLabelTextFont is not nothing then
		put mLabelTextFont into rProp["labelTextFont"]
	end if
	put mPercent into rProp["percentageValue"]
	put mShowPercentageValue into rProp["showPercentageValue"]
	put mOnlyFillWhileMoving into rProp["onlyFillWhileMoving"]

	/*
	put the bounding box of mThumbVector into tThumbBounds
	put the height of tThumbBounds into mThumbHeight
	put the width of tThumbBounds into mThumbWidth

	mOnlyFillWhileMoving
   mMouseDown
	mRailBarColor
   put (my height / 2) +mMargin into mTop
   put (my width / 2) +mMargin into mFillBarRight
    mFillBarRect
	*/
end handler
public handler OnLoad(in rProp as Array)
	put my script object into mE
	if "margin" is not among the keys of rProp then
		put 32 into mMargin
	else
		put rProp["margin"] into mMargin
	end if

	if "label" is not among the keys of rProp then
		put nothing into mLabel
	else
		put rProp["label"] into mLabel
	end if
	if "cornerRadius" is not among the keys of rProp then
		put 15 into mCornerRadius
	else
		put rProp["cornerRadius"] into mCornerRadius
	end if
	put rProp["horizontalOrentation"] into mHoriz
	if "borderWidth" is not among the keys of rProp then
		put 0 into mBorderWidth
	else
		put rProp["borderWidth"] into mBorderWidth
	end if
	setThumbShape( rProp["thumbShape"] )
	if rProp["thumbShape"] is "custom" then
		setThumbSVGPath( rProp["thumbSVGPath"] )
	end if
	if "thumbFillColor" is not among the keys of rProp then
		put the color of my foreground paint into mThumbFillColor
	else
		put stringToColor( rProp["thumbFillColor"]) into mThumbFillColor
	end if
	if "labelTextColor" is not among the keys of rProp then
		put the color of my foreground paint into mLabelTextColor
	else
		put stringToColor( rProp["labelTextColor"]) into mLabelTextColor
	end if
	if "labelTextSize" is among the keys of rProp then
		put rProp["labelTextSize"] into mLabelTextSize
	end if
	if "labelTextFont" is among the keys of rProp then
		put rProp["labelTextFont"] into mLabelTextFont
	end if

	put rProp["percentageValue"] into mPercent
	setPercentVal(mPercent)
	put rProp["showPercentageValue"] into mShowPercentageValue
	put rProp["onlyFillWhileMoving"] into mOnlyFillWhileMoving

	if "hiliteColor" is not among the keys of rProp then
		put the color of my focus paint into mHiliteColor
	else
		put stringToColor( rProp["hiliteColor"]) into mHiliteColor
	end if

	-- OnMouseMove()
end handler

--------------------------------------------------------------------------  Creating & Redrawing --------------------------------------------------------------------------------------

private variable mThumbHeight as optional Real
private variable mThumbWidth as optional Real

--- called when widget is created

variable mHiliteColor as optional Color

private variable mMargin as Number
property margin           get mMargin           set setMargin
public handler setMargin(in pMargin as Number)
	put pMargin into mMargin
	OnGeometryChanged()
	redraw all
end handler

private variable mE as ScriptObject
public handler OnCreate()
	put my script object into mE
	variable tThumbBounds as optional Rectangle
	put "thumb" into mThumbShape
    put path "M19.957,39.487c7.348,0,13.839-10.771,15.539-14.278s2.589-11.26,2.589-13.175v-3.241c0-.025,0-3.392,0-3.392,0-1.915-1.159-3.467-2.589-3.467,0,0-8.308-.711-15.539-.687-7.231.024-15.453.687-15.453.687-1.43,0-2.589,1.552-2.589,3.467v6.633c0,1.915.648,9.725,2.589,13.175s6.865,14.278,15.453,14.278Z" into mThumbVector
	put the bounding box of mThumbVector into tThumbBounds
	put the height of tThumbBounds into mThumbHeight
	put the width of tThumbBounds into mThumbWidth

	-- put the color of my highlight paint into mHiliteColor
	put the color of my focus paint into mHiliteColor -- on macOS focus color is what we want not 'the highlight paint'
	-- set the alpha of mHiliteColor to 1.0
	-- log [the alpha of mHiliteColor]
	put mThumbWidth into mMargin
   -- log [mMargin,mThumbHeight,mThumbWidth]
	put 15 into mCornerRadius
	put false into mOnlyFillWhileMoving
   put true into mHoriz
   put false into mMouseDown
	--
	put color [ 0.5, 0.5, 0.5, 0.5 ] into mRailBarColor -- 50% Grey / 50% Opaque
	put color [ 0.9, 0.9, 0.9, 1.0 ] into mThumbFillColor -- 50% Grey / 50% Opaque

	-- create intitial 50% position bar
   put 0.33 into mPercentVal
	put 0.33 into mPercent
   put (my height / 2) +mMargin into mTop
   put (my width / 2) +mMargin into mFillBarRight
   if mHoriz then
		put rectangle [0 + mMargin, 0 + mMargin, mFillBarRight, my height -mMargin] into mFillBarRect
   else
		put rectangle [0 + mMargin, mTop , my width -mMargin, my height -mMargin ] into mFillBarRect
   end if
   redraw all
end handler

-- this handler is called when a card containg the widget is opened
public handler OnOpen()
   OnGeometryChanged()
   redraw all
end handler

------------------------------ Main Rendering ------------------------------
public handler OnPaint()
   set the antialias of this canvas to true
	variable tPath as Path
	variable tH as Integer
	variable tW as Integer
	put my height into tH
   put my width into tW

	if mOnlyFillWhileMoving is false then --- rendereed while dragging
		set the paint of this canvas to solid paint with mHiliteColor
		fill rounded rectangle path of mFillBarRect with radius mCornerRadius on this canvas
	end if

  variable tRailThinkness as Real
   ------------------------------ Horizontal orientation ------------------------------
   if mHoriz then
		put tH * 0.5 into tRailThinkness
      -- set the stroke width of this canvas to tRailThinkness
	   set the paint of this canvas to solid paint with mRailBarColor
		--------------------- paint slider rail --------------------------
      -- stroke line path from point [0 +mMargin, tH/2 +mMargin] to point[ tW -mMargin, tH/2 -mMargin] on this canvas
		/*fill rounded rectangle path of rectangle \
		     [0 +mMargin, my height/2 -(tRailThinkness/2), my width -mMargin, my height/2 +(tRailThinkness/2) ] \
			      with radius mCornerRadius on this canvas
		*/
		fill rounded rectangle path of rectangle \
									  [0+mMargin, 0+mMargin, my width - mMargin , my height -mMargin ] \
											with radius mCornerRadius on this canvas

    if mBorderWidth > 0 then
        if mForegroundColor is not nothing then
        	set the paint of this canvas to solid paint with mHiliteColor
		else -- inherit the color
			set the paint of this canvas to my foreground paint
		end if
		set the stroke width of this canvas to mBorderWidth
		stroke rounded rectangle path of rectangle \
										[0+mMargin, 0+mMargin, my width - mMargin , my height -mMargin ] \
											with radius mCornerRadius on this canvas
     end if

		--------------------- paint fill bar --------------------------
      if mFillBarRect is not nothing then
         if mMouseDown then --- rendereed while dragging slider
				set the paint of this canvas to solid paint with color [the red of mHiliteColor,the green of mHiliteColor,the blue of mHiliteColor, 1.0 * mPercentVal  ]
            fill rounded rectangle path of mFillBarRect with radius mCornerRadius on this canvas

			end if
			-------------------- PAINT THE THUMNB SVG PATH --------------------
	      begin layer with outer shadow effect on this canvas
				put mThumbVector into tPath
			   translate tPath by [ mFillBarRight - (mThumbWidth/2) , tH/2 - (mThumbHeight/2) ]
			   set the paint of this canvas to solid paint with mThumbFillColor
				fill tPath on this canvas
	      end layer on this canvas
   end if

      ------------------------------ Vertical orientation ------------------------------
   else
		put tW * 0.5 into tRailThinkness
		set the paint of this canvas to solid paint with mRailBarColor
		-- set the paint of this canvas to my background paint -- mRailBarColor

      -- stroke line path from point [tW/2 +mMargin, 0 +mMargin ] to point [tW/2 -mMargin, tH -mMargin] on this canvas

		/*fill rounded rectangle path of rectangle \
		     [my width/2 -(tRailThinkness/2), 0+mMargin, my width/2 +(tRailThinkness/2), my height -mMargin ] \
			      with radius mCornerRadius on this canvas
		*/
		fill rounded rectangle path of rectangle \
					     [0+mMargin, 0+mMargin, my width - mMargin , my height -mMargin ] \
						      with radius mCornerRadius on this canvas

		if mBorderWidth > 0 then
			set the stroke width of this canvas to mBorderWidth

			if mForegroundColor is not nothing then
        		set the paint of this canvas to solid paint with mHiliteColor
			else -- inherit the color
				set the paint of this canvas to my foreground paint
			end if

			stroke rounded rectangle path of rectangle \
					  [0+mMargin, 0+mMargin, my width - mMargin , my height -mMargin ] \
							with radius mCornerRadius on this canvas
		end if

      if mFillBarRect is not nothing then
         if mMouseDown then --- rendereed while dragging slider
				set the paint of this canvas to solid paint with color [the red of mHiliteColor,the green of mHiliteColor,the blue of mHiliteColor, mPercentVal  ]
            fill rounded rectangle path of mFillBarRect with radius mCornerRadius on this canvas
         end if
			--------------------- PAINT THE THUMNB SVG PATH  -------------------
         begin layer with outer shadow effect on this canvas
				put mThumbVector into tPath
				rotate tPath by -90 -- ROTATE PATH FOR VERTICAL
				translate tPath by [tW/2 - (mThumbHeight/2), mTop + (mThumbWidth/2) ]
				set the paint of this canvas to solid paint with mThumbFillColor
            fill tPath on this canvas
         end layer on this canvas
      end if
   end if

   if mLabel is not nothing and mLabel is not the empty string then
		variable tTextBounds as Rectangle
		variable tTextVOffset as Real
		variable tTextHOffset as Real

		set the font of this canvas to my font
		measure mLabel on this canvas
		put the result into tTextBounds
		put rectangle path of tTextBounds into tPath
		put ( the bottom of my bounds - the bottom of tTextBounds ) into tTextVOffset
		put ( the right of my bounds - the right of tTextBounds ) into tTextHOffset
		if mLabelTextColor is not nothing then
			set the paint of this canvas to solid paint with mLabelTextColor
		else
			set the paint of this canvas to my foreground paint
		end if
	  if mLabelAlign is "Center" then
		  fill text mLabel at center of my bounds on this canvas
	  else if mLabelAlign is "Left" or mLabelAlign is "" then
		  fill text mLabel at top left of my bounds on this canvas
	  else if mLabelAlign is "CenterLeft" then
		  -- fill text mLabel at center left of my bounds on this canvas
		  fill text mLabel at point [ the left of my bounds, tTextVOffset /2 + (the size of my font / 2)] on this canvas
	  else if mLabelAlign is "Right" then
		  fill text mLabel at top right of my bounds on this canvas
		  -- fill text mLabel at point [the right of my bounds - the right of tTextBounds,the size of my font] on this canvas
	  else if mLabelAlign is "CenterRight" then
		 -- 	fill text mLabel at center of my bounds on this canvas
		 fill text mLabel at point [ tTextHOffset , tTextVOffset /2 + (the size of my font / 2)] on this canvas
	  else if mLabelAlign is "CenterBottom" then
		  fill text mLabel at bottom of my bounds on this canvas
		  -- fill text mLabel at point [ (tTextHOffset/2), the bottom of my bounds - (the size of my font / 2) ] on this canvas
	  else if mLabelAlign is "CenterTop" then
		  fill text mLabel at top of my bounds on this canvas
		  -- fill text mLabel at point [ tTextHOffset / 2, 0 + the size of my font ] on this canvas
	  else if mLabelAlign is "BottomLeft" then
		  fill text mLabel at bottom left of my bounds on this canvas
	  else if mLabelAlign is "BottomRight" then
		  fill text mLabel at bottom right of my bounds on this canvas
	  else
        fill text mLabel at top of my bounds on this canvas
	  end if
   end if

    if mShowPercentageValue then
     set the font of this canvas to my font
	    if mForegroundColor is not nothing then
        	set the paint of this canvas to solid paint with mHiliteColor
		else -- inherit the color
			set the paint of this canvas to my foreground paint
		end if
      -- fill text mLabel at point [tW * 0.5, tH * 0.5 ]  on this canvas
     ---  fill text mLabel at top left of my bounds on this canvas
      fill text (mPercent formatted as string) at bottom of my bounds on this canvas
   end if
      --------- Outline the Widget's rect --------
    	-- set the stroke width of this canvas to (tW * 0.02)
      -- set the paint of this canvas to solid paint with color [0,0,0,1]
      -- stroke rectangle path of rectangle[0,0, tW, tH] on this canvas
 end handler

 public handler OnGeometryChanged()
    if mHoriz then
       put ( ( my width - mMargin *2) * mPercentVal ) + mMargin into mFillBarRight
       put rectangle [0 +mMargin, 0 +mMargin, mFillBarRight , my height -mMargin] into mFillBarRect
       -- log [mPercentVal, mFillBarRight]
    else
       put  ( ( my height - mMargin * 2 ) * mPercentVal ) +mMargin  into mTop
       -- put rectangle [0, my height/2 - tSliderHeight/2, my idth, my height/2 + tSliderHeight/2] into mSliderBounds
       put rectangle [0 + mMargin, mTop, my width -mMargin, my height -mMargin ] into mFillBarRect
       --  log [mPercentVal, mTop]
    end if
    -- redraw all
 end handler
 --------------------------------------------------------  Mouse Handlers ------------------------------------------------------------
 -- * scrollbarBeginning pStart
 -- * scrollbarEnd pEnd
 -- * scrollbarDrag pNewPosition
 -- Not currently used, may be more useful for a 'stepper' control
 -- scrollbarLineInc pNewPosition
 -- scrollbarLineDec pNewPosition
 -- scrollbarPageInc pNewPosition
 -- scrollbarPageDec pNewPosition

 public handler OnMouseUp()
     put false into mMouseDown
     if the mouse position is within my bounds then
       post "mouseUp" with [the click button] -- to my script object
     else
        post "mouseRelease" with [the click button]
     end if
     post "scrollbarEnd" with [mPercentVal]
     redraw all
   end handler

   public handler OnMouseDown()
      put true into mMouseDown
      post "mouseDown" to my script object with [the click button] -- to my script object
      post "scrollbarBeginning" to my script object with [mPercentVal] -- to my script object
      OnMouseMove()
   end handler

   public handler OnMouseMove()
      if mMouseDown is not nothing and mMouseDown is true then
			-- grab the mouse location
         variable tPosition as Point
         put the mouse position into tPosition

			---- redefine the rect of the fillbar to reflect current mose posiont
         ------------------------------ Horizontal orientation
         if mHoriz then
				--- check that are not past the width of the widget on the left or right,
				-- log [tPosition]
				-- if the x of tPosition < 0+mMargin or the x of tPosition > my width -mMargin then
				-- if the x of tPosition < 0 then
			  --		return -- exits the handler
				-- end if
				-- let the script engine know the control is moving:
				post "mouseMove" with [the x of tPosition, the y of tPosition]

				put the x of tPosition into mFillBarRight
            put ((my width - mMargin*2) - (the x of tPosition -mMargin) ) into mPercentVal
            put 1 - (mPercentVal / (my width - mMargin*2) ) into mPercentVal
            if mPercentVal >= 1.0 then
               put 1.0 into mPercentVal
					put my width - mMargin into mFillBarRight
					put rectangle [0 +mMargin, 0+mMargin, mFillBarRight, my height - mMargin] into mFillBarRect
            end if
            if mPercentVal <= 0.001 then
               put 0 into mPercentVal
               put rectangle [0 +mMargin ,0 +mMargin ,0 +mMargin ,0 +mMargin ] into mFillBarRect
               put mMargin into mFillBarRight
            else
               put rectangle [0 +mMargin, 0+mMargin, mFillBarRight, my height - mMargin] into mFillBarRect
            end if
			   put mPercentVal into mPercent
				-- log [mPercentVal,mPercent]
            -- log [mFillBarRight]
         ------------------------------ Vertical orientation
         else
				--- check that are not past the width of the widget on the left or right,
				-- log [tPosition]
				-- if the y of tPosition < 0+mMargin or the y of tPosition > my height -mMargin then
				-- if the x of tPosition < 0 then
				--	return -- exits the handler
				-- end if
				-- let the script engine know the control is moving:
				post "mouseMove" with [the x of tPosition, the y of tPosition]

				put the y of tPosition into mTop
            put (my height -(mMargin*2) ) - ( the y of tPosition -(mMargin) ) into mPercentVal
            put mPercentVal / (my height -(mMargin*2) ) into mPercentVal

            if mPercentVal >= 1.0 then
               put 1.0 into mPercentVal
               put 0+ mMargin into mTop
					put rectangle [0 +mMargin, mTop, my width - mMargin, my height -mMargin] into mFillBarRect
            else if mPercentVal <= 0.001 then
               put 0 into mPercentVal
               put my height -mMargin into mTop
               put rectangle [0 +mMargin, mTop +mMargin, 0+mMargin, 0+mMargin] into mFillBarRect
            else
					-- log [mPercentVal, mTop]
               put rectangle [0 +mMargin, mTop, my width -mMargin, my height -mMargin ] into mFillBarRect
            end if
				put mPercentVal into mPercent
				-- log [mPercentVal, mPercent]
         end if

         post "scrollbarDrag" with [mPercent]
      end if
   redraw all
end handler

public handler OnMouseCancel()
   -- put false into mMouseButtonDown
   OnMouseUp()
end handler

