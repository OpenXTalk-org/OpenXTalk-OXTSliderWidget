private variable mHoriz as Boolean
property horizontalOrentation	 get mHoriz	  set setHorizOrientation
metadata horizontalOrentation.editor is "com.livecode.pi.boolean"
metadata horizontalOrentation.label is "Horizontal orientation"
metadata horizontalOrentation.default is "false"
metadata horizontalOrentation.section is "Basic"
public handler setHorizOrientation(in pBoolean as Boolean)
	put pBoolean into mHoriz
	--- swap the height and width
	variable tW as Number
	variable tH as Number
	put my width into tW
	put my height into tH
	put property "width" of mE into tH
	put property "height" of mE into tW
	set property "width" of mE to tW
	set property "height" of mE to tH
	-- log [tH,tW]
	-- /*
   if mHoriz then
   	-- put mPercentVal into mPercent
	else
		-- put mPercentVal into mPercent
		put 1 - mPercentVal into mPercentVal
	end if
	-- */
	setPercentVal( mPercent )
	-- OnMouseMove()
   OnGeometryChanged()
	-- setPercentVal( mPercent )
	redraw all
end handler

private variable mForegroundColor as optional Color
property "foregroundColor" get getForegroundColor set setForegroundColor
metadata foregroundColor.editor is "com.livecode.pi.color"
metadata foregroundColor.default is ""
metadata foregroundColor.section is "Colors"
metadata foregroundColor.label is "Fill color"
metadata foregroundColor.group is "Foreground fill"
public handler getForegroundColor() returns String
	if mForegroundColor is nothing then
		return ""
	else
     	return colorToString( mForegroundColor, false)
	end if
end handler
public handler setForegroundColor(in pColor as String) returns nothing
	if pColor is "" then
		put nothing into mForegroundColor
	else
    	put stringToColor(pColor) into mForegroundColor
	end if
   redraw all
end handler

