private variable mMouseDown as optional Boolean

private variable mFillBarRect as Rectangle
private variable mTop as Number
private variable mFillBarRight as Number

private variable mPercent as Real
private variable mPercentVal as Real
property percentageValue	 get getPercentVal	  set setPercentVal
metadata percentageValue.editor is "com.livecode.pi.real"
public handler setPercentVal(in pPercent as Real)
	/*
	if pPercent = mPercent then
		return
	end if
   */
	put pPercent into mPercent
	if mPercent >= 1.0 then
		put 1.0 into mPercent
	else if mPercent <= 0.001 then
		put 0 into mPercent
	end if
   if mHoriz then
	  put mPercent into mPercentVal
	else
		put 1- mPercent into mPercentVal
		put mPercent into mPercent
	end if
   OnGeometryChanged()
	redraw all
end handler
private handler getPercentVal() returns Real
		return mPercent
end handler

private variable mShowPercentageValue as Boolean
property showPercentageValue	 get mShowPercentageValue	  set setShowPercentageValue
metadata showPercentageValue.editor is "com.livecode.pi.boolean"
metadata showPercentageValue.label is "Show Percentage Value"
metadata showPercentageValue.default is "false"
metadata showPercentageValue.section is "Basic"
public handler setShowPercentageValue(in pBoolean as Boolean)
