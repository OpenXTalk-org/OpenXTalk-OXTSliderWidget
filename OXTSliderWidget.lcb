private variable mLabelAlign as String
property "labelAlign"       get mLabelAlign      set setLabelAlign
metadata labelAlign.section is "Text"
metadata labelAlign.editor is "com.livecode.pi.enum"
metadata labelAlign.options is "Center,CenterLeft,CenterRight,CenterTop,CenterBottom,Left,BottomLeft,Right,BottomRight"
metadata labelAlign.default is "Center"
metadata labelAlign.label is "Label text alignment"
public handler setLabelAlign( in pAlign as String)
   if pAlign is "Center" or pAlign is "CenterLeft" or pAlign is "CenterRight" or pAlign is "CenterTop" or pAlign is "CenterBottom" \
       or pAlign is "Left" or pAlign is "BottomLeft" or pAlign is "Right" or pAlign is "BottomRight" then
      put pAlign into mLabelAlign
   else
      throw "labelAlign must be one of Center,CenterLeft,CenterRight,CenterTop,CenterBottom,Left,BottomLeft,Right,BottomRight, or empty"
      put "Center" into mLabelAlign
   end if
	-- OnGeometryChanged()
	redraw all
end handler

